content = """\
# ─────────────────────────────────────────
#  .gitignore — Sistema de Detecção de EPI
# ─────────────────────────────────────────

# ── Ambientes virtuais ──
venv/
.venv/
env/
.env/
ENV/

# ── Python cache ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ── Distribuição / build ──
dist/
build/
*.egg-info/
*.egg

# ── Modelos treinados (grandes demais para o Git) ──
*.pt
*.pth
*.onnx
*.engine
*.tflite

# ── Logs e saídas geradas ──
logs/
*.log
*.json
*.csv
runs/

# ── Chave Firebase (NUNCA subir!) ──
*.json
firebase_key.json
serviceAccountKey.json

# ── Imagens e vídeos de teste ──
*.mp4
*.avi
*.mov
*.jpg
*.jpeg
*.png
*.bmp

# ── Jupyter Notebooks checkpoints ──
.ipynb_checkpoints/

# ── IDEs ──
.vscode/
.idea/
*.suo
*.user

# ── Sistema operacional ──
.DS_Store
Thumbs.db
desktop.ini

# ── Variáveis de ambiente ──
.env
.env.*
"""

with open(".gitignore", "w", encoding="utf-8") as f:
    f.write(content)

print(".gitignore criado com sucesso!")